                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">The configuration file is an alternative location to backup and restore your settings. This is only maintained by this application. So save these values to Current if you want to use a traditional Nextion screen.</property>
