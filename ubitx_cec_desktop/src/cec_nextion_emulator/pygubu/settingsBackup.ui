<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings>
      <setting id="name">settingsBackup</setting>
      <setting id="description">used to bachup and restore critical values</setting>
      <setting id="template">widget</setting>
      <setting id="main_widget">labelframe1</setting>
      <setting id="module_namespace" />
      <setting id="module_name">settingsBackup</setting>
      <setting id="main_classname">settingsBackup</setting>
      <setting id="output_dir">..</setting>
      <setting id="builder_namespace">custom_widgets</setting>
      <setting id="output_dir2">..</setting>
      <setting id="generate_code_onsave">False</setting>
      <setting id="use_i18n">False</setting>
      <setting id="all_ids_attributes">False</setting>
      <setting id="import_tkvariables">False</setting>
      <setting id="use_ttk_styledefinition_file">True</setting>
      <setting id="use_window_centering_code">False</setting>
      <setting id="ttk_style_definition_file">../mystyles.py</setting>
    </settings>
    <customwidgets />
    <resources />
  </project>
  <object class="tk.Toplevel" id="settingsBackup_Toplevel" named="True">
    <property name="title" translatable="yes">Radio Backup</property>
    <child>
      <object class="ttk.Labelframe" id="labelframe1">
        <property name="height">400</property>
        <property name="style">Heading2.TLabelframe</property>
        <property name="text" translatable="yes">Radio Backup</property>
        <property name="width">600</property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="frame1">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">true</property>
              <property name="fill">both</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="backupSettings_Frame" named="True">
                <property name="height">200</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">200</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="expand">true</property>
                  <property name="fill">x</property>
                  <property name="side">top</property>
                </layout>
                <containerlayout manager="grid">
                  <property name="anchor">center</property>
                </containerlayout>
                <child>
                  <object class="ttk.Label" id="select_Label" named="True">
                    <property name="anchor">w</property>
                    <property name="justify">right</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Select</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">5</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="selectLabel_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">This column allows you to select individual settings to copy. Or you can click the bottom Select All to select all the settings.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="setting_Label" named="True">
                    <property name="anchor">w</property>
                    <property name="justify">right</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Setting</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">5</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="setting_Label_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">Identifies the name of the individual settings you can copy.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="facotryValue_Label" named="True">
                    <property name="anchor">e</property>
                    <property name="justify">center</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Factory
Value</property>
                    <layout manager="grid">
                      <property name="column">2</property>
                      <property name="row">0</property>
                      <property name="sticky">ew</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="factoryValue_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">This columns contains the Factory settings. If you replaced your Raduino, these values might be incorrect.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="currentSettings_Label" named="True">
                    <property name="anchor">e</property>
