            </child>
            <child>
              <object class="ttk.Frame" id="action_Frame" named="True">
                <property name="height">200</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">200</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="expand">true</property>
                  <property name="fill">x</property>
                  <property name="pady">10 0</property>
                  <property name="side">top</property>
                </layout>
                <containerlayout manager="grid">
                  <property name="anchor">center</property>
                </containerlayout>
                <child>
                  <object class="ttk.Label" id="from_Label" named="True">
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Source:</property>
                    <layout manager="grid">
                      <property name="column">2</property>
                      <property name="padx">10 0</property>
                      <property name="row">0</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="from_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">This menu selects where the settings will COME FROM.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="to_Label" named="True">
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Destination:</property>
                    <layout manager="grid">
                      <property name="column">4</property>
                      <property name="padx">40 0</property>
                      <property name="row">0</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="to_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">This menu selects where the settings will BE COPIED TO.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Menubutton" id="from_Menubutton" named="True">
                    <property name="style">Heading0.TMenubutton</property>
                    <property name="text" translatable="yes">Select</property>
                    <property name="textvariable">string:from_Source_VAR</property>
                    <property name="width">10</property>
                    <layout manager="grid">
                      <property name="column">3</property>
                      <property name="padx">15 5</property>
                      <property name="pady">10</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                    <child>
                      <object class="tk.Menu" id="from_Menu" named="True">
                        <property name="tearoff">false</property>
                        <child>
                          <object class="tk.Menuitem.Command" id="from_Factory_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectFrom_Factory_CB</property>
                            <property name="font">{Arial} 24 {}</property>
                            <property name="label" translatable="yes">Factory</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                        <child>
                          <object class="tk.Menuitem.Command" id="from_Current_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectFrom_Current_CB</property>
                            <property name="font">{Arial} 24 {}</property>
                            <property name="label" translatable="yes">Current</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                        <child>
                          <object class="tk.Menuitem.Command" id="from_ConfigFile_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectFrom_ConfigFile_CB</property>
                            <property name="font">{Arial} 24 {}</property>
                            <property name="label" translatable="yes">ConfigFile</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Menubutton" id="to_Menubutton" named="True">
                    <property name="style">Heading0.TMenubutton</property>
                    <property name="text" translatable="yes">Select</property>
                    <property name="textvariable">string:to_Source_VAR</property>
                    <property name="width">10</property>
                    <layout manager="grid">
                      <property name="column">5</property>
                      <property name="padx">15 10</property>
                      <property name="pady">10</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                    <child>
                      <object class="tk.Menu" id="to_Menu" named="True">
                        <property name="tearoff">false</property>
                        <child>
                          <object class="tk.Menuitem.Command" id="to_Current_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectTo_Current_CB</property>
                            <property name="font">{Arial} 24 {}</property>
                            <property name="label" translatable="yes">Current</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                        <child>
                          <object class="tk.Menuitem.Command" id="to_ConfigFile_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectTo_ConfigFile_CB</property>
                            <property name="font">{Arial} 24 {}</property>
                            <property name="label" translatable="yes">ConfigFile</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="closingFrame" named="True">
                <property name="height">50</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">200</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="expand">false</property>
                  <property name="pady">20</property>
                  <property name="side">top</property>
                </layout>
                <child>
                  <object class="ttk.Button" id="copy_Button" named="True">
                    <property name="command" type="command" cbtype="simple">copy_CB</property>
                    <property name="style">Button2b.TButton</property>
                    <property name="text" translatable="yes">Copy</property>
                    <layout manager="pack">
                      <property name="padx">10</property>
                      <property name="side">left</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="copyButton_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">Starts the copy from Source to Destination.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="cancel_Buttom" named="True">
                    <property name="command" type="command" cbtype="simple">cancel_CB</property>
                    <property name="style">Button2b.TButton</property>
                    <property name="text" translatable="yes">Cancel</property>
                    <layout manager="pack">
                      <property name="padx">10</property>
                      <property name="side">left</property>
                    </layout>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="cancelButton_Tooltip" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">Cancels the operation without making any changes.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
