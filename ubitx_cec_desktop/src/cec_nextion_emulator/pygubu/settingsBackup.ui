                    <child>
                      <object class="ttk.Button" id="select_All" named="True">
                        <property name="command" type="command" cbtype="simple">select_All_Checkbutton_CB</property>
                        <property name="style">Button2Raised.TButton</property>
                        <property name="text" translatable="yes">Select All</property>
                        <property name="textvariable">string:select_All_VAR</property>
                        <property name="width">10</property>
                        <layout manager="pack">
                          <property name="pady">15</property>
                        </layout>
