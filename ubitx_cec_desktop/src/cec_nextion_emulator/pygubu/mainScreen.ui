                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="cwDecodeFrame" named="True">
                <property name="height">100</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">400</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10 0</property>
                  <property name="pady">10 0</property>
                  <property name="row">2</property>
                  <property name="sticky">nw</property>
                </layout>
                <child>
                  <object class="tk.Text" id="decodedCWText" named="True">
                    <property name="background">gray</property>
                    <property name="borderwidth">2</property>
                    <property name="font">{Courier New} 18 {}</property>
                    <property name="foreground">white</property>
                    <property name="height">3</property>
                    <property name="highlightbackground">white</property>
                    <property name="highlightcolor">white</property>
                    <property name="highlightthickness">1</property>
                    <property name="relief">flat</property>
                    <property name="spacing1">2</property>
                    <property name="spacing2">5</property>
                    <property name="spacing3">2</property>
                    <property name="state">normal</property>
                    <property name="width">25</property>
                    <property name="wrap">char</property>
                    <layout manager="pack">
                      <property name="expand">false</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="tk.Canvas" id="spectrumCanvas" named="True">
                    <property name="background">gray</property>
                    <property name="height">100</property>
                    <property name="highlightbackground">white</property>
                    <property name="highlightcolor">white</property>
                    <property name="highlightthickness">1</property>
                    <property name="relief">flat</property>
                    <property name="width">200</property>
                    <layout manager="pack">
                      <property name="anchor">sw</property>
                      <property name="expand">false</property>
                      <property name="padx">10 0</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="tuningArrow_Labelframe" named="True">
                <property name="height">200</property>
                <property name="style">Heading3.TLabelframe</property>
                <property name="text" translatable="yes">Tuning</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">3</property>
                  <property name="padx">650 0</property>
                  <property name="pady">0</property>
                  <property name="row">1</property>
                  <property name="rowspan">3</property>
                  <property name="sticky">sw</property>
                </layout>
                <child>
                  <object class="tk.Canvas" id="downButton_Canvas" named="True">
                    <property name="background">gray</property>
                    <property name="borderwidth">0</property>
                    <property name="height">140</property>
                    <property name="highlightthickness">0</property>
                    <property name="selectborderwidth">0</property>
                    <property name="width">140</property>
                    <bind sequence="&lt;ButtonPress&gt;" handler="downButtonPressed_CB" add="True" />
                    <bind sequence="&lt;ButtonRelease&gt;" handler="downButtonReleased_CB" add="" />
                    <layout manager="pack">
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="tk.Canvas" id="upButton_Canvas" named="True">
                    <property name="background">gray</property>
                    <property name="borderwidth">0</property>
                    <property name="height">140</property>
                    <property name="highlightthickness">0</property>
                    <property name="selectborderwidth">0</property>
                    <property name="width">140</property>
                    <bind sequence="&lt;ButtonPress&gt;" handler="upButtonPressed_CB" add="True" />
                    <bind sequence="&lt;ButtonRelease&gt;" handler="upButtonReleased_CB" add="" />
                    <layout manager="pack">
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="pygubu.widgets.Tooltip" id="tuning_Tooltip" named="True">
                    <property name="padx">8</property>
                    <property name="relief">raised</property>
                    <property name="text" translatable="yes">Click the up arrow to go up the current tuning factor. Down decreases the frequency by the tuning factor.</property>
                    <property name="wraplength">300</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="ttk.Frame" id="ATT_IFS_Adjust_Frame" named="True">
        <property name="style">Normal.TFrame</property>
        <property name="width">1250</property>
        <layout manager="pack">
          <property name="anchor">w</property>
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="pady">10 50</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="att_ifs_Frame" named="True">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">400</property>
            <layout manager="pack">
              <property name="anchor">nw</property>
              <property name="expand">false</property>
              <property name="fill">x</property>
              <property name="padx">10</property>
              <property name="side">left</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="ATT_Frame" named="True">
                <property name="height">200</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">200</property>
                <layout manager="pack">
                  <property name="padx">30</property>
                  <property name="side">left</property>
                </layout>
                <child>
                  <object class="projectcustom.Jogwheel" id="ATT_Jogwheel" named="True">
                    <property name="button_radius">25</property>
                    <property name="command" type="command" cbtype="simple">updateATTValue_CB</property>
                    <property name="divisions">10</property>
                    <property name="end">255</property>
                    <property name="radius">200</property>
                    <property name="scroll_steps">10</property>
                    <property name="start">0</property>
                    <property name="state">disabled</property>
                    <property name="touchOptimized">False</property>
                    <property name="value">70</property>
                    <bind sequence="&lt;ButtonPress&gt;" handler="ATT_Jogwheel_ButtonPressed_CB" add="True" />
                    <bind sequence="&lt;ButtonRelease&gt;" handler="ATT_Jogwheel_ButtonReleased_CB" add="True" />
                    <layout manager="pack">
                      <property name="anchor">center</property>
                      <property name="padx">20 0</property>
                      <property name="side">top</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="ATT_Status_Label" named="True">
                    <property name="style">Heading2b.TLabel</property>
                    <property name="text" translatable="yes">ATT (OFF)</property>
                    <property name="textvariable">string:ATT_Status_VAR</property>
                    <layout manager="pack">
                      <property name="anchor">center</property>
                      <property name="side">bottom</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="pygubu.widgets.Tooltip" id="ATT_Tooltip" named="True">
                    <property name="padx">8</property>
                    <property name="relief">raised</property>
                    <property name="text" translatable="yes">Click to enable ATT. Move the dial to adjust the ATT. Click in plac to disable ATT.</property>
                    <property name="wraplength">300</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="IFS_Frame" named="True">
                <property name="height">200</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">200</property>
                <layout manager="pack">
                  <property name="side">left</property>
                </layout>
                <child>
                  <object class="projectcustom.Jogwheel" id="IFS_Jogwheel" named="True">
                    <property name="button_radius">25</property>
                    <property name="command" type="command" cbtype="simple">updateIFSValue_CB</property>
                    <property name="divisions">150</property>
                    <property name="end">2000</property>
                    <property name="radius">200</property>
                    <property name="scroll_steps">150</property>
                    <property name="start">-2000</property>
                    <property name="state">disabled</property>
                    <property name="touchOptimized">False</property>
                    <property name="value">0</property>
                    <bind sequence="&lt;ButtonPress&gt;" handler="IFS_Jogwheel_ButtonPressed_CB" add="True" />
                    <bind sequence="&lt;ButtonRelease&gt;" handler="IFS_Jogwheel_ButtonReleased_CB" add="True" />
                    <layout manager="pack">
                      <property name="anchor">center</property>
                      <property name="padx">20 0</property>
                      <property name="side">top</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="IFS_Status_Label" named="True">
                    <property name="style">Heading2b.TLabel</property>
                    <property name="text" translatable="yes">IFS (OFF)</property>
                    <property name="textvariable">string:IFS_Status_VAR</property>
                    <layout manager="pack">
                      <property name="anchor">center</property>
                      <property name="side">bottom</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="pygubu.widgets.Tooltip" id="IFS_Tooltip" named="True">
                    <property name="justify">left</property>
                    <property name="padx">8</property>
                    <property name="relief">raised</property>
                    <property name="text" translatable="yes">Click to enable IFS. Move the dial to adjust the IFS. Click in plac to disable IFS.</property>
                    <property name="wraplength">300</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="ttk.Frame" id="cwInfoFrame" named="True">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="padx">50 0</property>
              <property name="pady">15 0</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="cw_Info_Frame" named="True">
                <property name="borderwidth">5</property>
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                <layout manager="pack">
                  <property name="anchor">nw</property>
                  <property name="expand">false</property>
                  <property name="fill">x</property>
                  <property name="pady">0 10</property>
                  <property name="side">top</property>
                </layout>
                <child>
                  <object class="ttk.Label" id="cw_settings_title_Label" named="True">
                    <property name="style">Heading2b.TLabel</property>
                    <property name="text" translatable="yes">CW Settings</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="columnspan">3</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="tone_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Tone</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="row">1</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="tone_value_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">799</property>
                    <property name="textvariable">string:tone_value_VAR</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">0 2</property>
                      <property name="row">1</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="tone_units_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Hz</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">2</property>
                      <property name="row">1</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="key_type_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Key</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="row">2</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="key_type_value_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Straight</property>
                    <property name="textvariable">string:key_type_value_VAR</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="row">2</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="key_speed_label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Speed</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="row">3</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="key_speed_value_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">1</property>
                    <property name="textvariable">string:key_speed_value_VAR</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="row">3</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="key_speed_units_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">wpm</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">2</property>
                      <property name="row">3</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="delay_returning_to_rx_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Delay-&gt;RX</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">0 3</property>
                      <property name="row">5</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="delay_returning_to_rx_value_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">199</property>
                    <property name="textvariable">string:delay_returning_to_rx_value_VAR</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="row">5</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="delay_returning_to_rx_units_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">ms</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">2</property>
                      <property name="row">5</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="delay_starting_tx_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">Delay-&gt;TX</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="row">4</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="delay_starting_tx_value_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">299</property>
                    <property name="textvariable">string:delay_starting_tx_value_VAR</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="row">4</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="delay_starting_tx_units_Label" named="True">
                    <property name="style">Heading3b.TLabel</property>
                    <property name="text" translatable="yes">ms</property>
                    <bind sequence="&lt;1&gt;" handler="cwSettings_CB" add="" />
                    <layout manager="grid">
                      <property name="column">2</property>
                      <property name="row">4</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="pygubu.widgets.Tooltip" id="cw_Settings_Frame_Tooltips" named="True">
                    <property name="justify">left</property>
                    <property name="padx">8</property>
                    <property name="relief">raised</property>
                    <property name="text" translatable="yes">Current CW Settings. Click to go into the CW Settings Menu to edit them.</property>
                    <property name="wraplength">300</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
