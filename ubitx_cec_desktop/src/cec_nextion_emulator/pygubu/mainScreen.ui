                        <layout manager="grid">
                          <property name="column">1</property>
                          <property name="padx">0 5</property>
                          <property name="row">0</property>
                          <property name="sticky">e</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="PWR_Label" named="True">
                        <property name="style">Heading3b.TLabel</property>
                        <property name="text" translatable="yes">PWR:</property>
                        <layout manager="grid">
                          <property name="column">0</property>
                          <property name="padx">5 0</property>
                          <property name="pady">0 5</property>
                          <property name="row">1</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="PWR_Value" named="True">
                        <property name="anchor">e</property>
                        <property name="style">Heading4b.TLabel</property>
                        <property name="textvariable">string:PWR_Value_VAR</property>
                        <property name="width">4</property>
                        <layout manager="grid">
                          <property name="column">1</property>
                          <property name="padx">0 5</property>
