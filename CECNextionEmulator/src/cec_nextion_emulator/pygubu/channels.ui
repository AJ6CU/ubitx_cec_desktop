<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings>
      <setting id="name">CW Settings Window</setting>
      <setting id="description">Used to save cw settings</setting>
      <setting id="module_name">channels</setting>
      <setting id="template">widget</setting>
      <setting id="main_widget">labelframe1</setting>
      <setting id="main_classname">channels</setting>
      <setting id="main_menu" />
      <setting id="output_dir">..</setting>
      <setting id="output_dir2">..</setting>
      <setting id="import_tkvariables">False</setting>
      <setting id="use_ttk_styledefinition_file">True</setting>
      <setting id="use_i18n">False</setting>
      <setting id="all_ids_attributes">False</setting>
      <setting id="generate_code_onsave">False</setting>
      <setting id="use_window_centering_code">False</setting>
      <setting id="ttk_style_definition_file">../mystyles.py</setting>
    </settings>
    <customwidgets>
      <customwidget path="../frequencyChannelbo.py" />
    </customwidgets>
    <resources />
  </project>
  <object class="tk.Toplevel" id="channels_Window" named="True">
    <property name="height">800</property>
    <property name="width">800</property>
    <child>
      <object class="ttk.Labelframe" id="labelframe1">
        <property name="height">600</property>
        <property name="style">Heading2.TLabelframe</property>
        <property name="text" translatable="yes">Frequency Channels</property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="frame1">
            <property name="style">Normal.TFrame</property>
            <property name="width">750</property>
            <layout manager="pack">
              <property name="expand">true</property>
              <property name="fill">both</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="display_Current_VFO_Frame" named="True">
                <property name="height">24</property>
                <property name="style">Normal.TFrame</property>
                <property name="width">450</property>
                <layout manager="pack">
                  <property name="expand">true</property>
                  <property name="fill">x</property>
                  <property name="side">top</property>
                </layout>
                <child>
                  <object class="ttk.Label" id="current_VFO_Heading_Label" named="True">
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Current VFO:</property>
                    <layout manager="pack">
                      <property name="anchor">center</property>
                      <property name="padx">75 0</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="channel_Text_Label" named="True">
                    <property name="style">Heading2b.TLabel</property>
                    <property name="text" translatable="yes">Channel:</property>
                    <layout manager="pack">
                      <property name="padx">10 0</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="current_Channel" named="True">
                    <property name="style">Heading2bi.TLabel</property>
                    <property name="text" translatable="yes">Not Saved</property>
                    <property name="textvariable">string:current_Channel_VAR</property>
                    <property name="width">10</property>
                    <layout manager="pack">
                      <property name="padx">5 0</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="current_VFO_Label" named="True">
                    <property name="style">Heading2b.TLabel</property>
                    <property name="text" translatable="yes">99.999.99</property>
                    <property name="textvariable">string:current_VFO_VAR</property>
                    <layout manager="pack">
                      <property name="padx">10 0</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="current_Mode_Label" named="True">
                    <property name="style">Heading2b.TLabel</property>
                    <property name="text" translatable="yes">CWL</property>
                    <property name="textvariable">string:current_Mode_VAR</property>
                    <layout manager="pack">
                      <property name="expand">false</property>
                      <property name="padx">10 10</property>
                      <property name="side">left</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="frame2">
                <property name="height">800</property>
                <property name="style">Normal.TFrame</property>
                <layout manager="pack">
                  <property name="expand">true</property>
                  <property name="fill">both</property>
                  <property name="side">top</property>
                </layout>
                <child>
                  <object class="ttk.Frame" id="header_Line_Frame" named="True">
                    <property name="height">24</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">450</property>
                    <layout manager="pack">
                      <property name="expand">true</property>
                      <property name="fill">x</property>
                    </layout>
                    <child>
                      <object class="ttk.Label" id="channel_header_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Chan</property>
                        <layout manager="grid">
                          <property name="column">0</property>
                          <property name="padx">10 0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="name_Header_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Name</property>
                        <layout manager="grid">
                          <property name="column">1</property>
                          <property name="padx">165 0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="frequency_Header_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Freq</property>
                        <layout manager="grid">
                          <property name="column">2</property>
                          <property name="padx">95 0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="mode_Header_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Mode</property>
                        <layout manager="grid">
                          <property name="column">4</property>
                          <property name="padx">80 0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="showLabel_Header_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Visible</property>
                        <layout manager="grid">
                          <property name="column">5</property>
                          <property name="padx">75 0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="scan_Set_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Scan
Set</property>
                        <layout manager="grid">
                          <property name="column">6</property>
                          <property name="padx">80 7</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="dirtyIndicator_Label" named="True">
                        <property name="style">Heading2b.TLabel</property>
                        <property name="text" translatable="yes">Saved</property>
                        <layout manager="grid">
                          <property name="column">7</property>
                          <property name="padx">30</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Frame" id="frameSizer" named="True">
                    <property name="height">550</property>
                    <property name="style">Normal.TFrame</property>
                    <layout manager="pack">
                      <property name="expand">true</property>
                      <property name="fill">both</property>
                      <property name="side">left</property>
                    </layout>
                    <containerlayout manager="pack">
                      <property name="propagate">false</property>
                    </containerlayout>
                    <child>
                      <object class="pygubu.widgets.ScrolledFrame" id="scrolledChannelFrame" named="True">
                        <property name="relief">flat</property>
                        <property name="scrolltype">vertical</property>
                        <property name="style">Normal.TFrame</property>
                        <property name="usemousewheel">true</property>
                        <layout manager="pack">
                          <property name="anchor">w</property>
                          <property name="expand">true</property>
                          <property name="fill">both</property>
                        </layout>
                        <child>
                          <object class="projectcustom.frequencyChannel" id="frequencyChannel1" named="True">
                            <layout manager="pack">
                              <property name="anchor">w</property>
                              <property name="expand">true</property>
                              <property name="fill">x</property>
                              <property name="side">top</property>
                            </layout>
                          </object>
                        </child>
                        <child>
                          <object class="projectcustom.frequencyChannel" id="frequencyChannel2" named="True">
                            <layout manager="pack">
                              <property name="anchor">w</property>
                              <property name="pady">10 0</property>
                              <property name="side">top</property>
                            </layout>
                          </object>
                        </child>
