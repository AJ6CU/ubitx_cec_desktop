<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings>
      <setting id="name">settingsAbout</setting>
      <setting id="description">Used to save general settings</setting>
      <setting id="template">widget</setting>
      <setting id="main_widget">labelframe1</setting>
      <setting id="module_namespace" />
      <setting id="module_name">settingsAbout</setting>
      <setting id="main_classname">settingsAbout</setting>
      <setting id="output_dir">..</setting>
      <setting id="builder_namespace">custom_widgets</setting>
      <setting id="output_dir2">..</setting>
      <setting id="generate_code_onsave">False</setting>
      <setting id="use_i18n">False</setting>
      <setting id="all_ids_attributes">False</setting>
      <setting id="import_tkvariables">False</setting>
      <setting id="use_ttk_styledefinition_file">True</setting>
      <setting id="use_window_centering_code">False</setting>
      <setting id="ttk_style_definition_file">../mystyles.py</setting>
    </settings>
    <customwidgets />
    <resources />
  </project>
  <object class="tk.Toplevel" id="settingsAbout_Toplevel" named="True">
    <property name="height">550</property>
    <property name="title" translatable="yes">Settings</property>
    <property name="width">550</property>
    <child>
      <object class="ttk.Labelframe" id="labelframe1">
        <property name="style">Heading2.TLabelframe</property>
        <property name="text" translatable="yes">About CECNextionEmulator</property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="general_Settings_Frame" named="True">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="padx">10</property>
              <property name="pady">10</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Label" id="version_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Version:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">10</property>
                  <property name="row">0</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="versionID_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">2.0</property>
                <property name="textvariable">string:versionID_VAR</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">10</property>
                  <property name="row">0</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="date_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Date:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">1</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="releaseDate_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">January 1, 1957</property>
                <property name="textvariable">string:releaseDate_VAR</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">1</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="author_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Author:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">2</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="authorName_Label" named="True">
                <property name="justify">left</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Mark Hatch (AJ6CU)</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">2</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="email_Label" named="True">
                <property name="justify">left</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">email:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">3</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="emailAddress_Label" named="True">
                <property name="justify">left</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">markjhatch@gmail.com</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">3</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="configurationFile_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Configuration FIle:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">4</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="tk.Entry" id="configurationFileLocation_Entry" named="True">
                <property name="background">gray</property>
                <property name="borderwidth">0</property>
                <property name="font">{Arial} 14 {bold}</property>
                <property name="foreground">white</property>
                <property name="highlightbackground">gray</property>
                <property name="readonlybackground">gray</property>
                <property name="state">readonly</property>
                <property name="text" translatable="yes">&gt;&gt;&gt;location&lt;&lt;&lt;</property>
                <property name="textvariable">string:configurationFileLocation_VAR</property>
                <property name="width">50</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">4</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="logFile_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Log FIle:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">5</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="tk.Entry" id="logFileLocation_Entry" named="True">
                <property name="background">gray</property>
                <property name="borderwidth">0</property>
                <property name="font">{Arial} 14 {bold}</property>
                <property name="foreground">white</property>
                <property name="highlightbackground">gray</property>
                <property name="readonlybackground">gray</property>
                <property name="state">readonly</property>
                <property name="text" translatable="yes">&gt;&gt;&gt;location&lt;&lt;&lt;</property>
                <property name="textvariable">string:logFileLocation_VAR</property>
                <property name="width">50</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">5</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="license_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">License:</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">8</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="gplV3_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">GPL V3</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">8</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="license_ID" named="True">
                <property name="justify">left</property>
                <property name="style">Heading2b.TLabel</property>
                <property name="text" translatable="yes">https://www.gnu.org/licenses/gpl-3.0.en.html</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">0 10</property>
                  <property name="row">9</property>
                  <property name="sticky">w</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="ttk.Frame" id="closingFrame" named="True">
            <property name="height">50</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">false</property>
              <property name="pady">20</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Button" id="close_Button" named="True">
                <property name="command" type="command" cbtype="simple">close_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Close</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
