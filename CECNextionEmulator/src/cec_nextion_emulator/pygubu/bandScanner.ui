            <child>
              <object class="ttk.Button" id="scan_Button" named="True">
                <property name="command" type="command" cbtype="simple">scan_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Scan</property>
                <property name="textvariable">string:scan_Button_VAR</property>
                <property name="width">10</property>
                <layout manager="pack">
                  <property name="padx">0 20</property>
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="close_Button" named="True">
                <property name="command" type="command" cbtype="simple">close_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Close</property>
                <property name="width">10</property>
                <layout manager="pack">
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
