<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings>
      <setting id="name">settingsMachine</setting>
      <setting id="description">Used to save of machines</setting>
      <setting id="template">widget</setting>
      <setting id="main_widget">labelframe1</setting>
      <setting id="module_namespace" />
      <setting id="module_name">settingsMachine</setting>
      <setting id="main_classname">settingsMachine</setting>
      <setting id="output_dir">..</setting>
      <setting id="builder_namespace">custom_widgets</setting>
      <setting id="output_dir2">..</setting>
      <setting id="generate_code_onsave">False</setting>
      <setting id="use_i18n">False</setting>
      <setting id="all_ids_attributes">False</setting>
      <setting id="import_tkvariables">False</setting>
      <setting id="use_ttk_styledefinition_file">True</setting>
      <setting id="use_window_centering_code">False</setting>
      <setting id="ttk_style_definition_file">../mystyles.py</setting>
    </settings>
    <customwidgets />
    <resources />
  </project>
  <object class="tk.Toplevel" id="settings_Window" named="True">
    <property name="title" translatable="yes">Machine Settings</property>
    <child>
      <object class="ttk.Labelframe" id="labelframe1">
        <property name="cursor">arrow</property>
        <property name="style">Heading2.TLabelframe</property>
        <property name="text" translatable="yes">Machine Settings ( Caution Advised)</property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="frame1">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">true</property>
              <property name="fill">both</property>
              <property name="padx">10</property>
              <property name="pady">10</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="DSP_Frame" named="True">
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">2</property>
                  <property name="row">0</property>
                  <property name="sticky">ew</property>
                </layout>
                <child>
                  <object class="ttk.Label" id="DSP_Enable_Label" named="True">
                    <property name="state">disabled</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Enable DSP Processor</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">5</property>
                      <property name="pady">5 0</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Menubutton" id="DSP_Enable_Menubutton" named="True">
                    <property name="style">Heading0.TMenubutton</property>
                    <property name="textvariable">string:DSP_Enable_VAR</property>
                    <property name="width">5</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">43 10</property>
                      <property name="pady">5 0</property>
                      <property name="row">0</property>
                    </layout>
                    <child>
                      <object class="tk.Menu" id="DSP_Enable_Menu" named="True">
                        <property name="tearoff">false</property>
                        <child>
                          <object class="tk.Menuitem.Command" id="selectDSP_On_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectDSP_On_CB</property>
                            <property name="font">{Arial} 36 {}</property>
                            <property name="label" translatable="yes">True</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                        <child>
                          <object class="tk.Menuitem.Command" id="selectDSP_Off_Command" named="True">
                            <property name="command" type="command" cbtype="simple">selectDSP_Off_CB</property>
                            <property name="font">{Arial} 36 {}</property>
                            <property name="label" translatable="yes">False</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="DSPMessage_Label" named="True">
                    <property name="style">Heading2bi.TLabel</property>
                    <property name="text" translatable="yes">No DSP Found on startup. Option automatically disabled</property>
                    <property name="textvariable">string:DSPMessage_VAR</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="columnspan">2</property>
                      <property name="padx">5</property>
                      <property name="pady">0 10</property>
                      <property name="row">2</property>
                      <property name="sticky">ew</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="PWR_SWR_Frame" named="True">
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">2</property>
                  <property name="pady">10 0</property>
                  <property name="row">2</property>
                  <property name="sticky">ew</property>
                </layout>
                <child>
                  <object class="ttk.Label" id="PWR_SWR_Enable_Label" named="True">
                    <property name="state">disabled</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Enable PWR/SWR Meter</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">5</property>
                      <property name="pady">10 0</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Menubutton" id="PWR_SWR_Menubutton" named="True">
                    <property name="style">Heading0.TMenubutton</property>
                    <property name="textvariable">string:PWR_SWR_Enable_VAR</property>
                    <property name="width">5</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">10</property>
                      <property name="pady">10 0</property>
                      <property name="row">0</property>
                      <property name="sticky">e</property>
                    </layout>
                    <child>
                      <object class="tk.Menu" id="PWR_SWR_Menu" named="True">
                        <property name="tearoff">false</property>
                        <child>
                          <object class="tk.Menuitem.Command" id="enablePWR_SWR_Command" named="True">
                            <property name="command" type="command" cbtype="simple">enablePWR_SWR_CB</property>
                            <property name="font">{Arial} 36 {}</property>
                            <property name="label" translatable="yes">True</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                        <child>
                          <object class="tk.Menuitem.Command" id="disablePWR_SWR_Command" named="True">
                            <property name="command" type="command" cbtype="simple">disablePWR_SWR_CB</property>
                            <property name="font">{Arial} 36 {}</property>
                            <property name="label" translatable="yes">False</property>
                            <property name="state">normal</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="PWR_Factor_Label" named="True">
                    <property name="state">disabled</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">PWR Adjustment Factor
(0.0-nn.nn)</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">20 5</property>
                      <property name="pady">10 0</property>
                      <property name="row">1</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="PWR_Factor_Entry" named="True">
                    <property name="font">{Arial} 36 {}</property>
                    <property name="justify">right</property>
                    <property name="text" translatable="yes">0.0</property>
                    <property name="textvariable">string:PWR_Factor_VAR</property>
                    <property name="validate">focusout</property>
                    <property name="validatecommand" type="command" cbtype="entry_validate" args="%P %V">PWR_Factor_Validation_CB</property>
                    <property name="width">5</property>
                    <bind sequence="&lt;Button&gt;" handler="PWR_Factor_Entered_CB" add="True" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">10</property>
                      <property name="pady">10 0</property>
                      <property name="row">1</property>
                      <property name="sticky">e</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="SWR_Factor_Label" named="True">
                    <property name="state">disabled</property>
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">SWR Adjustment Factor
(0.0-nn.nn)</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">20 5</property>
                      <property name="pady">10</property>
                      <property name="row">2</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="SWR_Factor_Entry" named="True">
                    <property name="font">{Arial} 36 {}</property>
                    <property name="justify">right</property>
                    <property name="text" translatable="yes">0.0</property>
                    <property name="textvariable">string:SWR_Factor_VAR</property>
                    <property name="validate">focusout</property>
                    <property name="validatecommand" type="command" cbtype="entry_validate" args="%P %V">SWR_Factor_Validation_CB</property>
                    <property name="width">5</property>
                    <bind sequence="&lt;Button&gt;" handler="SWR_Factor_Entered_CB" add="True" />
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">10</property>
                      <property name="pady">10</property>
                      <property name="row">2</property>
                      <property name="sticky">e</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="Timing_Frame" named="True">
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">2</property>
                  <property name="pady">10</property>
                  <property name="row">4</property>
                  <property name="sticky">ew</property>
                </layout>
                <child>
                  <object class="ttk.Label" id="MCU_Command_Headroom_Label" named="True">
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Minimum time between
commands sent to
Radio (ms):</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">5</property>
                      <property name="pady">10 0</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Spinbox" id="MCU_Command_Headroom_Spinbox" named="True">
                    <property name="font">{Arial} 36 {}</property>
                    <property name="from_">1</property>
                    <property name="justify">right</property>
                    <property name="style">Custom.TSpinbox</property>
                    <property name="textvariable">string:MCU_Command_Headroom_VAR</property>
                    <property name="to">20</property>
                    <property name="width">4</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">15 10</property>
                      <property name="pady">10 0</property>
                      <property name="row">0</property>
                      <property name="sticky">e</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="MCU_Update_Period_Label" named="True">
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Frequency to check for
UX changes (ms):</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">5</property>
                      <property name="pady">15 0</property>
                      <property name="row">2</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Spinbox" id="MCU_Update_Period_Spinbox" named="True">
                    <property name="font">{Arial} 36 {}</property>
                    <property name="from_">1</property>
                    <property name="justify">right</property>
                    <property name="style">Custom.TSpinbox</property>
                    <property name="textvariable">string:MCU_Update_Period_VAR</property>
                    <property name="to">20</property>
                    <property name="width">4</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">15 10</property>
                      <property name="pady">15 0</property>
                      <property name="row">2</property>
                      <property name="sticky">e</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="MCU_Read_Wait_Period_Label" named="True">
                    <property name="style">Heading1b.TLabel</property>
                    <property name="text" translatable="yes">Wait time for completion 
of data transfer from
MCU/DPS (ms):</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">5</property>
                      <property name="pady">15 10</property>
                      <property name="row">3</property>
                      <property name="sticky">w</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Spinbox" id="MCU_Read_Wait_Period_Spinbox" named="True">
                    <property name="font">{Arial} 36 {}</property>
                    <property name="from_">1</property>
                    <property name="justify">right</property>
                    <property name="style">Custom.TSpinbox</property>
                    <property name="textvariable">string:MCU_Read_Wait_Period_VAR</property>
                    <property name="to">20</property>
                    <property name="width">4</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="padx">15 10</property>
                      <property name="pady">15 10</property>
                      <property name="row">3</property>
                      <property name="sticky">e</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="ttk.Frame" id="closingFrame" named="True">
            <property name="height">50</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">false</property>
              <property name="pady">20</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Button" id="apply_Button" named="True">
                <property name="command" type="command" cbtype="simple">apply_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Apply</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="cancel_Buttom" named="True">
                <property name="command" type="command" cbtype="simple">cancel_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Cancel</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
