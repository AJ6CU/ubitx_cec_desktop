<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings>
      <setting id="name">settingsLogbook</setting>
      <setting id="description">Manages the settings for the logbook function</setting>
      <setting id="template">widget</setting>
      <setting id="main_widget">labelframe1</setting>
      <setting id="module_namespace" />
      <setting id="module_name">settingsLogbook</setting>
      <setting id="main_classname">settingsLogbook</setting>
      <setting id="output_dir">..</setting>
      <setting id="builder_namespace">custom_widgets</setting>
      <setting id="output_dir2">..</setting>
      <setting id="generate_code_onsave">False</setting>
      <setting id="use_i18n">False</setting>
      <setting id="all_ids_attributes">False</setting>
      <setting id="import_tkvariables">False</setting>
      <setting id="use_ttk_styledefinition_file">True</setting>
      <setting id="use_window_centering_code">False</setting>
      <setting id="ttk_style_definition_file">../mystyles.py</setting>
    </settings>
    <customwidgets />
    <resources />
  </project>
  <object class="tk.Toplevel" id="settingsLogbook_Toplevel" named="True">
    <property name="title" translatable="yes">Settings</property>
    <child>
      <object class="ttk.Labelframe" id="labelframe1">
        <property name="style">Heading2.TLabelframe</property>
        <property name="text" translatable="yes">Logbook Settings</property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="general_Settings_Frame" named="True">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="padx">10</property>
              <property name="pady">10</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Label" id="logbookSwitch_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Logbook On</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">40 20</property>
                  <property name="row">1</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Menubutton" id="logbookSwitch_Menbutton" named="True">
                <property name="style">Heading0.TMenubutton</property>
                <property name="textvariable">string:logbookSwitch_VAR</property>
                <property name="width">5</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">15 5</property>
                  <property name="pady">40 20</property>
                  <property name="row">1</property>
                  <property name="sticky">w</property>
                </layout>
                <child>
                  <object class="tk.Menu" id="logbookSwitch_Menu" named="True">
                    <property name="tearoff">false</property>
                    <child>
                      <object class="tk.Menuitem.Command" id="selectLogbookOn_Command" named="True">
                        <property name="command" type="command" cbtype="simple">selectLogbookOn_CB</property>
                        <property name="font">{Arial} 36 {}</property>
                        <property name="label" translatable="yes">True </property>
                        <property name="state">normal</property>
                      </object>
                    </child>
                    <child>
                      <object class="tk.Menuitem.Command" id="selectLogbookOff_Command" named="True">
                        <property name="command" type="command" cbtype="simple">selectLogbookOff_CB</property>
                        <property name="font">{Arial} 36 {}</property>
                        <property name="label" translatable="yes">False</property>
                        <property name="state">normal</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="logbookType_Label" named="True">
                <property name="justify">right</property>
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Logbook Type</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">40 20</property>
                  <property name="row">2</property>
                  <property name="sticky">e</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Menubutton" id="logbookType_Menubutton" named="True">
                <property name="style">Heading0.TMenubutton</property>
                <property name="textvariable">string:logbookType_VAR</property>
                <property name="width">5</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">15 5</property>
                  <property name="pady">40 20</property>
                  <property name="row">2</property>
                  <property name="sticky">w</property>
                </layout>
                <child>
                  <object class="tk.Menu" id="logbookType_Menu" named="True">
                    <property name="tearoff">false</property>
                    <child>
                      <object class="tk.Menuitem.Command" id="selectLogbookType_CSV_Command" named="True">
                        <property name="command" type="command" cbtype="simple">selectLogbookType_CSV_CB</property>
                        <property name="font">{Arial} 36 {}</property>
                        <property name="label" translatable="yes">CSV</property>
                        <property name="state">normal</property>
                      </object>
                    </child>
                    <child>
                      <object class="tk.Menuitem.Command" id="selectLogbookType_ADI_Command" named="True">
                        <property name="command" type="command" cbtype="simple">selectLogbookType_ADI_CB</property>
                        <property name="font">{Arial} 36 {}</property>
                        <property name="label" translatable="yes">ADI</property>
                        <property name="state">normal</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="pygubu.widgets.PathChooserButton" id="logbookFileSelectorButton" named="True">
                <property name="initialdir">~</property>
                <property name="mustexist">true</property>
                <property name="style">Button2Sunken.TButton</property>
                <property name="text" translatable="yes">Select
Logbook
Location</property>
                <property name="textvariable">string:logbookDirectoryLocation_VAR</property>
                <property name="type">directory</property>
                <bind sequence="&lt;&lt;PathChooserPathChanged&gt;&gt;" handler="newLogbookLocation_CB" add="True" />
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="padx">10</property>
                  <property name="pady">40 10</property>
                  <property name="row">4</property>
                  <property name="sticky">nse</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="tk.Text" id="logbookLocation_Text" named="True">
                <property name="background">gray</property>
                <property name="borderwidth">0</property>
                <property name="font">{Arial} 14 {bold}</property>
                <property name="foreground">white</property>
                <property name="height">3</property>
                <property name="highlightbackground">gray</property>
                <property name="highlightcolor">gray</property>
                <property name="highlightthickness">0</property>
                <property name="inactiveselectbackground">gray</property>
                <property name="insertbackground">gray</property>
                <property name="insertborderwidth">0</property>
                <property name="selectbackground">blue</property>
                <property name="selectborderwidth">0</property>
                <property name="selectforeground">gray</property>
                <property name="width">50</property>
                <property name="wrap">char</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="row">4</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="logbookName_Label1" named="True">
                <property name="style">Heading1b.TLabel</property>
                <property name="text" translatable="yes">Logfile
Name</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="pady">20 0</property>
                  <property name="row">5</property>
                  <property name="sticky">nse</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="tk.Entry" id="logbookName_Entry" named="True">
                <property name="background">gray</property>
                <property name="borderwidth">0</property>
                <property name="font">{Arial} 14 {bold}</property>
                <property name="foreground">white</property>
                <property name="highlightbackground">gray</property>
                <property name="justify">left</property>
                <property name="readonlybackground">gray</property>
                <property name="state">readonly</property>
                <property name="textvariable">string:logbookName_VAR</property>
                <property name="width">40</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="padx">10</property>
                  <property name="pady">40 10</property>
                  <property name="row">5</property>
                  <property name="rowspan">1</property>
                  <property name="sticky">nsw</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="ttk.Frame" id="closingFrame" named="True">
            <property name="height">50</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">false</property>
              <property name="pady">20</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Button" id="apply_Button" named="True">
                <property name="command" type="command" cbtype="simple">apply_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Apply</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="cancel_Buttom" named="True">
                <property name="command" type="command" cbtype="simple">cancel_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="text" translatable="yes">Cancel</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
